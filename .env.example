DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DIRECT_TOKEN=your_oauth_token_here
DIRECT_CLIENT_LOGIN=your_client_login_here
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
